# Configuration de l'environnement - ctrlManage
# Copier ce fichier en .env et remplir les valeurs

# ============================================
# Base de données
# ============================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ctrlmanage?schema=public

# PostgreSQL (pour docker-compose)
POSTGRES_DB=ctrlmanage
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production

# ============================================
# Sécurité - JWT
# ============================================
# Générer une clé forte: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=8h

# ============================================
# Application
# ============================================
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ============================================
# Rate Limiting
# ============================================
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ============================================
# Redis (pour cache et rate limiting avancé)
# ============================================
REDIS_URL=redis://localhost:6379
CACHE_TTL=300
CACHE_MAX=100

# ============================================
# Sentry (optionnel - monitoring des erreurs)
# ============================================
SENTRY_DSN=

# ============================================
# Logging
# ============================================
LOG_LEVEL=debug
